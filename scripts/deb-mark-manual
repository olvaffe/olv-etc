#!/bin/sh

# for rescue (~300M)
cli_min="
	btrfs-progs
	dosfstools
	e2fsprogs
	fdisk
	init
	vim
"

# for all devices including servers (~100M)
cli_base="
	$cli_min
	curl
	htop
	iproute2
	iputils-ping
	ldnsutils
	less
	logrotate
	openssh-client
	openssh-server
	pciutils
	procps
	rsync
	sudo
	systemd-resolved
	usbutils
	whiptail
"

# for workstations, vms, and duts (~200M)
cli_std="
	$cli_base
	bc
	git
	locales
	lsof
	man-db
	manpages
	ncal
	python3
	python3-venv
	strace
	tmux
	unzip
	zip
"

# for workstations (~50M)
cli_full="
	$cli_std
	git-email
	jq
	msmtp
	picocom
	systemd-container
	wireguard-tools
"

# for terminal (~400M)
gui_min="
	alacritty
	fonts-noto-core
	i3status
	polkitd
	sway
"

# for basic use (~250M)
gui_base="
	$gui_min
	brightnessctl
	grim
	mesa-utils
	slurp
	swayidle
	swayimg
	swaylock
	vulkan-tools
	wayland-utils
	wl-clipboard
"

# for real use (~1100M)
gui_std="
	$gui_base
	fcitx5
	fcitx5-chewing
	fonts-noto-cjk
	fonts-noto-color-emoji
	google-chrome-stable
	mako-notifier
	pipewire-pulse
"

# for optional features (~500M)
gui_full="
	$gui_std
	cups
	mpv
	xdg-desktop-portal-gtk
	xdg-desktop-portal-wlr
"

# for tooling (~100M)
dev_min="
	gdb
	linux-perf
	manpages-dev
	trace-cmd
	universal-ctags
"

# for development (~700M)
dev_base="
	$dev_min
	build-essential
	ccache
	clang-format
	cmake
	meson
	pkgconf
"

# for cross-compile (~800M)
dev_cross="
	debootstrap
	gcc-aarch64-linux-gnu
	g++-aarch64-linux-gnu
	qemu-user
	qemu-user-binfmt
"

# for kernel (~100M)
# all except libelf-dev are for cros kernel
dev_kernel="
	cgpt
	device-tree-compiler
	libelf-dev
	lz4
	vboot-kernel-utils
"

# for mesa (~1000M)
dev_mesa="
	bison
	flex
	glslang-tools
	libclang-cpp-dev
	libclang-dev
	libclc-19-dev
	libdrm-dev
	libllvmspirvlib-19-dev
	libwayland-dev
	libx11-xcb-dev
	libxcb1-dev
	libxcb-dri3-dev
	libxcb-present-dev
	libxcb-randr0-dev
	libxcb-shm0-dev
	libxrandr-dev
	libxshmfence-dev
	llvm-dev
"

kernel_common="
	systemd-zram-generator
"

kernel_x86="
	$kernel_common
	linux-image-amd64
"

kernel_arm="
	$kernel_common
	linux-image-arm64
"

hw_x86="
	linux-cpupower
"

hw_uefi="
	systemd-ukify
"

hw_intel="
	firmware-intel-graphics
	firmware-iwlwifi
	intel-microcode
	mesa-vulkan-drivers
"

hw_wifi="
	iw
	iwd
	wireless-regdb
"

hw_usbnet="
	firmware-realtek
"

hw_rpi="
	cnrdrvcups-ufr2-us
	containers-storage
	git
	hdparm
	ksmbd-tools
	msmtp
	nginx
	php-fpm
	python3
	python3-venv
	podman
	systemd-journal-remote
	tmux
	zip
"

hw_npi="
	firmware-realtek
	kea-dhcp4-server
	nftables
	systemd-journal-remote
	unbound
"

cros_crostini="
	cros-guest-tools
"

pkgs=""

host="$(uname -n)"
case "$host" in
	"rpi")
		pkgs="$pkgs $cli_base $kernel_arm $hw_rpi"
		;;
	"npi")
		pkgs="$pkgs $cli_base $kernel_arm $hw_npi"
		;;
	"penguin")
		pkgs="$pkgs $cli_std $dev_min $cros_crostini"
		;;
	*)
		echo "unknown device: $host"
		exit 1
		;;
esac

manual="$(apt-mark showmanual)"
if [ -n "$manual" ]; then
	apt-mark auto $manual > /dev/null
fi

#apt install $pkgs
apt-mark manual $pkgs | grep -v ' set to manually installed\.$'
