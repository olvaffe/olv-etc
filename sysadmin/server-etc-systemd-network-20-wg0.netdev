[NetDev]
Name=wg0
Kind=wireguard

[WireGuard]
PrivateKey=<KEY>
ListenPort=51820

[WireGuardPeer]
PublicKey=<KEY>
AllowedIPs=192.168.87.20/32

# Peers' /etc/wireguard/wg0.conf should have
#
#   [Interface]
#   PrivateKey=<KEY>
#   Address=192.168.87.20/24
#
#   [Peer]
#   PublicKey=<KEY>
#   AllowedIPs=192.168.87.10/32
#   Endpoint=olv.rip:51820
